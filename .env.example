# ============================================================
#  ERP FÁBRICA DE PRODUCTOS DE LIMPIEZA
#  Variables de entorno — Copiar como .env en la raíz del proyecto
#  NUNCA subir este archivo al repositorio Git
# ============================================================

# ── Django ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-erp-limpieza-cambiar-en-produccion-$(python -c "import secrets; print(secrets.token_urlsafe(50))")
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 0.0.0.0
DJANGO_LOG_LEVEL=INFO

# ── Base de datos PostgreSQL ─────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=erp_limpieza
DB_USER=erp_user
DB_PASSWORD=Erp$2025#Limpieza
DB_HOST=localhost
DB_PORT=5432

# Para usar URL completa (alternativa a las variables anteriores):
# DATABASE_URL=postgresql://erp_user:Erp$2025#Limpieza@localhost:5432/erp_limpieza

# ── Redis (caché y colas — opcional) ────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Email ────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# En producción usar SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_de_aplicacion
DEFAULT_FROM_EMAIL=ERP Limpieza <no-reply@erp-limpieza.com>

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000 http://localhost:8080

# ── Empresa ───────────────────────────────────────────────────
EMPRESA_NOMBRE=Fábrica de Productos de Limpieza S.A.
EMPRESA_RUC=0990000001001
EMPRESA_CIUDAD=Guayaquil
EMPRESA_TELEFONO=04-2000000
EMPRESA_EMAIL=info@erp-limpieza.com
